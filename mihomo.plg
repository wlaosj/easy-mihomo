  };
  xhr.onerror = function(){
    if (uiUpdateInfo && !silent) {
      uiUpdateInfo.innerHTML = '<span style="color:#e74c3c;">网络错误</span>';
    }
  };
  xhr.send();
}

// 更新 UI 下载按钮状态
function updateUIDownloadButtonState() {
  var downloadBtn = document.getElementById('download-ui-btn');
  if (!downloadBtn) return;
  
  // 检查是否正在下载
  var progressBox = document.getElementById('progress-ui');
  if (progressBox && progressBox.textContent && progressBox.textContent.includes('%')) {
    downloadBtn.disabled = true;
    downloadBtn.style.background = '#777777';
    downloadBtn.style.cursor = 'not-allowed';
    downloadBtn.textContent = '下载中...';
    return;
  }
  
  // 启用按钮
  downloadBtn.disabled = false;
  downloadBtn.style.cursor = 'pointer';
  
  if (window.uiUpdateCheckData) {
    var data = window.uiUpdateCheckData;
    if (data.has_update) {
      if (data.local === 'not installed') {
        downloadBtn.style.background = '#27ae60';
        downloadBtn.textContent = '下载 UI';
      } else {
        downloadBtn.style.background = '#f39c12';
        downloadBtn.style.color = '#000';
        downloadBtn.textContent = '更新到 ' + data.remote;
      }
    } else {
      downloadBtn.style.background = '#777777';
      downloadBtn.textContent = '重新安装';
    }
  } else {
    downloadBtn.style.background = '#e67e22';
    downloadBtn.textContent = '下载/更新 UI';
  }
}

// 智能下载 UI 函数
function smartDownloadUI(target, btn) {
  // 检查是否正在下载
  var progressBox = document.getElementById('progress-ui');
  if (progressBox && progressBox.textContent && progressBox.textContent.includes('%')) {
    alert('Download in progress, please wait');
    return;
  }
  
  // 检查是否有更新信息
  if (!window.uiUpdateCheckData) {
    // 没有检查过更新，先检查
    if (confirm('Download latest UI?\n\nContinue?')) {
      startDownload(target, btn);
    }
    return;
  }
  
  var data = window.uiUpdateCheckData;
  
  // 根据更新状态给出不同提示
  if (data.has_update) {
    // 有新版本
    var confirmMsg = '';
    if (data.local === 'not installed') {
      confirmMsg = 'Download UI\n\nLatest: ' + data.remote + '\n\nContinue?';
    } else {
      confirmMsg = 'New version available\n\nCurrent: ' + data.local + '\nLatest: ' + data.remote + '\n\nUpdate?';
    }

    if (confirm(confirmMsg)) {
      startDownload(target, btn);
    }
  } else {
    // 已是最新版本，询问是否重新安装
    var reinstallMsg = 'Already latest: ' + data.remote + '\n\nReinstall?';
    if (confirm(reinstallMsg)) {
      startDownload(target, btn);
    }
  }
}

// 检查服务是否运行
function checkServiceRunning() {
  var statusElements = document.querySelectorAll('span[style*="color:#27ae60"]');
  for (var i = 0; i < statusElements.length; i++) {
    if (statusElements[i].textContent.includes('运行中')) {
      return true;
    }
  }
  return false;
}

// 更新下载按钮状态
function updateDownloadButtonState() {
  var downloadBtn = document.getElementById('download-btn');
  var updateInfo = document.getElementById('update-info');
  
  if (!downloadBtn) return;
  
  // 检查是否正在下载
  var progressBox = document.getElementById('progress-core');
  if (progressBox && progressBox.textContent && progressBox.textContent.includes('%')) {
    downloadBtn.disabled = true;
    downloadBtn.style.background = '#777777';
    downloadBtn.style.cursor = 'not-allowed';
    downloadBtn.textContent = '下载中...';
    return;
  }
  
  // 始终启用按钮（即使服务正在运行也允许下载核心）
  // 原因：下载核心需要魔法网络（代理），停止服务会导致无法下载
  // 新核心会保存到U盘并删除内存核心，重启服务后自动从U盘加载
  downloadBtn.disabled = false;
  downloadBtn.style.cursor = 'pointer';
  
  if (window.updateCheckData) {
    var data = window.updateCheckData;
    if (data.has_update) {
      if (data.local === 'not installed') {
        downloadBtn.style.background = '#27ae60';
        downloadBtn.textContent = '下载核心';
      } else {
        downloadBtn.style.background = '#f39c12';
        downloadBtn.style.color = '#000';
        downloadBtn.textContent = '更新到 ' + data.remote;
      }
    } else {
      downloadBtn.style.background = '#777777';
      downloadBtn.textContent = '重新安装';
    }
  } else {
    downloadBtn.style.background = '#e67e22';
    downloadBtn.textContent = '下载/更新核心';
  }
}

// 智能下载函数
function smartDownload(target, btn) {
  // 检查是否正在下载
  var progressBox = document.getElementById('progress-core');
  if (progressBox && progressBox.textContent && progressBox.textContent.includes('%')) {
    alert('Download in progress, please wait');
    return;
  }
  
  // 检查服务是否运行（用于提示，不阻止下载）
  var isServiceRunning = checkServiceRunning();
  
  // 检查是否有更新信息
  if (!window.updateCheckData) {
    // 没有检查过更新，先检查
    var msg = 'Download core\n\nContinue?';
    if (isServiceRunning) {
      msg = 'Download core\n\nNote: Service is running. Restart required after download.\n\nContinue?';
    }
    if (confirm(msg)) {
      startDownload(target, btn);
    }
    return;
  }
  
  var data = window.updateCheckData;
  
  // 根据更新状态给出不同提示
  if (data.has_update) {
    // 有新版本
    var confirmMsg = '';
    if (data.local === 'not installed') {
      confirmMsg = 'Download core\n\nLatest: ' + data.remote + '\n\nContinue?';
      if (isServiceRunning) {
        confirmMsg = 'Download core\n\nLatest: ' + data.remote + '\n\nNote: Service is running. Restart required after download.\n\nContinue?';
      }
    } else {
      confirmMsg = 'New version available\n\nCurrent: ' + data.local + '\nLatest: ' + data.remote + '\n\nUpdate?';
      if (isServiceRunning) {
        confirmMsg = 'New version available\n\nCurrent: ' + data.local + '\nLatest: ' + data.remote + '\n\nNote: Service is running. Restart required after download.\n\nUpdate?';
      }
    }
    
    if (confirm(confirmMsg)) {
      startDownload(target, btn);
    }
  } else {
    // 已是最新版本，询问是否重新安装
    var reinstallMsg = 'Already latest: ' + data.remote + '\n\nReinstall? (Can fix corrupted files)';
    if (isServiceRunning) {
      reinstallMsg = 'Already latest: ' + data.remote + '\n\nNote: Service is running. Restart required after download.\n\nReinstall?';
    }
    if (confirm(reinstallMsg)) {
      startDownload(target, btn);
    }
  }
}

function startDownload(target, btn) {
  // 清除旧的进度/错误信息（开始新操作）
  var progressBox = document.getElementById('progress-' + target);
  if (progressBox) {
    progressBox.innerHTML = '';
    progressBox.style.color = '';
    progressBox.style.opacity = '1';
  }
  
  // 禁用所有下载按钮，防止重复点击
  var downloadBtn = document.getElementById('download-btn');
  if (downloadBtn) {
    downloadBtn.dataset.oldText = downloadBtn.innerText;
    downloadBtn.dataset.oldColor = downloadBtn.style.background;
    downloadBtn.disabled = true;
    downloadBtn.style.background = '#777777';
    downloadBtn.style.cursor = 'not-allowed';
    downloadBtn.innerText = '下载中...';
  }
  
    var box = document.getElementById('download-msg');
    if (box) box.innerText = '已发起下载任务，正在准备...';
  
  var xhr = new XMLHttpRequest();
  xhr.open('GET', '/plugins/easy-mihomo/api.php?cmd=start_download&target=' + encodeURIComponent(target));
  xhr.onload = function(){
    if (xhr.status === 200) {
      if (box) box.innerText = (xhr.responseText || '').trim() || '任务已启动';
    } else {
      // 下载启动失败，恢复按钮
      if (downloadBtn) {
        downloadBtn.disabled = false;
        downloadBtn.style.background = downloadBtn.dataset.oldColor || '#e67e22';
        downloadBtn.style.cursor = 'pointer';
        downloadBtn.innerText = downloadBtn.dataset.oldText || '下载核心';
      }
      // 显示错误
      if (progressBox) {
        progressBox.innerHTML = 'Download failed, please retry';
        progressBox.style.color = '#e74c3c';
      }
    }
  };
  xhr.onerror = function(){
    // 网络错误，恢复按钮
    if (downloadBtn) {
      downloadBtn.disabled = false;
      downloadBtn.style.background = downloadBtn.dataset.oldColor || '#e67e22';
      downloadBtn.style.cursor = 'pointer';
      downloadBtn.innerText = downloadBtn.dataset.oldText || '下载核心';
    }
    // 显示错误
    if (progressBox) {
      progressBox.innerHTML = 'Network error, check connection';
      progressBox.style.color = '#e74c3c';
    }
  };
  xhr.send();
}

function pollProgress(target, elId) {
  var lastStatus = '';
  var errorTimeout = null;
  var autoHideTimeout = null;
  var intervalId = null;
  
  function tick(){
    var xhr = new XMLHttpRequest();
    xhr.open('GET', '/plugins/easy-mihomo/api.php?cmd=get_progress&target=' + encodeURIComponent(target));
    xhr.onload = function(){
      if (xhr.status === 200) {
        var box = document.getElementById(elId);
        if (!box) return;
        
        var txt = xhr.responseText || '';
        if (txt.trim()) {
          lastStatus = txt;
          
          // 检测错误信息
          if (txt.includes('error:')) {
            box.style.color = '#e74c3c';  // 红色
            box.style.opacity = '1';
            
            // 构建错误消息：错误内容 + 重试链接 + 关闭按钮
            var errorMsg = txt.replace('error:', 'Error:');
            box.innerHTML = errorMsg + 
              ' <a href="javascript:void(0)" onclick="smartDownload(\'' + target + '\', this); return false;" style="color:#007bff;text-decoration:underline;cursor:pointer;">重试</a>' +
              ' <span onclick="clearErrorMessage(\'' + elId + '\')" style="color:#999;margin-left:8px;cursor:pointer;font-size:18px;line-height:1;font-weight:bold;transition:color 0.2s;" title="关闭提示" onmouseover="this.style.color=\'#dc3545\'" onmouseout="this.style.color=\'#999\'">×</span>';
            
            // 清除之前的定时器
            if (errorTimeout) clearTimeout(errorTimeout);
            if (autoHideTimeout) clearTimeout(autoHideTimeout);
            
            // 10秒后半透明显示（提示信息已过期）
            errorTimeout = setTimeout(function() {
              if (box && box.innerHTML.includes('Error:')) {
                box.style.opacity = '0.6';

                // 再过20秒（总共30秒）自动消失
                autoHideTimeout = setTimeout(function() {
                  if (box && box.innerHTML.includes('Error:')) {
                    box.innerHTML = '';
                    box.style.opacity = '1';
                    box.style.color = '';
                  }
                }, 20000);
              }
            }, 10000);
            
          } else if (txt.includes('100%')) {
            // 下载完成
            box.style.color = '#27ae60';  // 绿色
            box.style.opacity = '1';
          box.innerText = txt;
            
            setTimeout(function(){
              if (box) {
                // 检查服务是否运行
                var isServiceRunning = checkServiceRunning();
                if (isServiceRunning && target === 'core') {
                  // 核心下载完成且服务正在运行
                  box.innerHTML = 'Core downloaded. <span style="color:#f39c12;font-weight:bold;">Restart service to apply.</span>';
                  // 不自动刷新页面，让用户看到提示
        } else {
                  // 服务未运行或下载的是UI，正常刷新
                  box.innerText = 'Download complete, refreshing...';
                  // 刷新页面以显示新版本
                  setTimeout(function(){
                    window.location.reload();
                  }, 2000);
                }
              }
            }, 1000);
            
          } else {
            // 正常进度
            box.style.color = '#777777';  // 灰色
            box.style.opacity = '1';
            box.innerText = txt;
          }
        } else {
          // 进度文件已被清理
          if (lastStatus && lastStatus.includes('%') && !lastStatus.includes('100%') && !lastStatus.includes('error:')) {
            // 如果之前有进度但不是100%或错误，现在没了，说明可能中断
            box.innerText = 'Download may have been interrupted';
            box.style.color = '#f39c12';
            setTimeout(function(){ if (box) box.innerText=''; }, 5000);
          } else if (lastStatus.includes('100%')) {
            // 已经完成了
            if (box) box.innerText = '';
          }
          lastStatus = '';
        }
      }
    };
    xhr.send();
  }
  
  tick();
  intervalId = setInterval(tick, 2000);
  return intervalId;
}

// 手动清除错误消息
function clearErrorMessage(elementId) {
  var box = document.getElementById(elementId);
  if (box) {
    box.innerHTML = '';
    box.style.opacity = '1';
    box.style.color = '';
  }
}

function openConfigEditor() {
  document.getElementById('configModal').style.display = 'block';
  // 禁用页面滚动
  document.body.style.overflow = 'hidden';
}

function closeConfigEditor() {
  document.getElementById('configModal').style.display = 'none';
  // 恢复页面滚动
  document.body.style.overflow = 'auto';
}

// 点击背景关闭弹出窗口
document.addEventListener('click', function(event) {
  var modal = document.getElementById('configModal');
  if (event.target === modal) {
    closeConfigEditor();
  }
});

// ESC键关闭弹出窗口
document.addEventListener('keydown', function(event) {
  if (event.key === 'Escape') {
    closeConfigEditor();
  }
});

