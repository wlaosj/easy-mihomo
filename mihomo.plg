      if (preg_match('/pid=(\d+)/', $statusText, $matches)) { $pid = $matches[1]; }
      echo '<div class="status-dot running"></div>';
      echo '<span class="status-text">' . t('running') . '</span>';
      if ($pid) echo '<span class="status-pid">' . t('pid') . ': ' . $pid . '</span>';
    } elseif (strpos($statusText, 'stopped') !== false) {
      echo '<div class="status-dot stopped"></div>';
      echo '<span class="status-text">' . t('stopped') . '</span>';
    } else {
      echo '<div class="status-dot unknown"></div>';
      echo '<span class="status-text">' . htmlspecialchars($statusText) . '</span>';
    }
  ?>
